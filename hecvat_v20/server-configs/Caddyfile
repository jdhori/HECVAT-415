# HECVAT 4.1.5 — Caddyfile
# Caddy automatically provisions and renews TLS certificates via Let's Encrypt.
# Replace hecvat.yourdomain.edu with your actual domain.
#
# Usage:  caddy run --config Caddyfile
# Docs:   https://caddyserver.com/docs/

hecvat.yourdomain.edu {

    # Serve files from this directory
    root * /var/www/hecvat
    file_server

    # Default page
    try_files {path} index.html

    # ── Security headers ──────────────────────────────────────────────
    # These HTTP headers take precedence over the equivalent <meta> tags
    # in index.html and provide stronger enforcement.

    header {
        # Content Security Policy
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none';"

        # Clickjacking protection
        X-Frame-Options "DENY"

        # MIME-type sniffing prevention
        X-Content-Type-Options "nosniff"

        # No referrer information sent on navigation
        Referrer-Policy "no-referrer"

        # Restrict browser feature APIs
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=()"

        # HSTS — Caddy handles HTTPS automatically, so this is safe to enable
        Strict-Transport-Security "max-age=31536000; includeSubDomains"

        # Do not expose server information
        -Server
    }

    # Cache control: HTML no-store, JS/CSS cached 1 hour
    @html {
        path *.html
    }
    header @html Cache-Control "no-store"

    @assets {
        path *.js *.css
    }
    header @assets Cache-Control "public, max-age=3600, must-revalidate"

    # Block hidden files
    @hidden {
        path /.*
    }
    respond @hidden 404
}
